# URL of your deployed Outpost relay server.
# This is a public endpoint address (not a secret) baked in as a default.
# Users can override it at runtime from the agent UI.
VITE_RELAY_URL=https://your-relay.up.railway.app

# NOTE: VITE_BOOTSTRAP_TOKEN is intentionally absent.
# The agent uses QR/code pairing (POST /agent/pair/:code/claim) which requires
# no embedded secret. Long-lived provisioning credentials must never be compiled
# into a distributed binary. See src-tauri/build.rs for details.
